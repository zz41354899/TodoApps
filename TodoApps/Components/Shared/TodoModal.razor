@using TodoApps.Models

@* 新增/編輯任務的 Modal 組件 *@

@if (IsVisible)
{
    <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);" @onclick="OnClose">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content" @onclick:stopPropagation="true">
                <div class="modal-body p-3 p-sm-4">
                    <div class="vstack gap-3">
                        <div class="d-flex align-items-center gap-3">
                            <button @onclick="ToggleIconPicker" class="btn btn-light fs-2 p-2">
                                @Todo.Icon
                            </button>
                            <input type="text" @bind="Todo.Title" placeholder="任務標題" class="form-control form-control-lg border-0 shadow-none fs-5 fw-medium" />
                            <button @onclick="() => Todo.IsStarred = !Todo.IsStarred" class="btn btn-link fs-4 p-0" style="transition: transform 0.15s;" onmouseover="this.style.transform='scale(1.1)'" onmouseout="this.style.transform='scale(1)'">
                                @(Todo.IsStarred ? "⭐" : "☆")
                            </button>
                        </div>
                        
                        @if (ShowIconPicker)
                        {
                            <IconPicker OnIconSelected="SelectIcon" />
                        }
                        
                        <textarea @bind="Todo.Description" rows="3" placeholder="新增描述..." class="form-control border-0 shadow-none small" style="resize: none;"></textarea>
                        
                        <div class="row g-3">
                            <div class="col-12 col-sm-6">
                                <label class="form-label small text-secondary mb-1">優先級</label>
                                <select @bind="Todo.Priority" class="form-select form-select-sm">
                                    <option value="Low">🟢 低</option>
                                    <option value="Medium">🟡 中</option>
                                    <option value="High">🔴 高</option>
                                </select>
                            </div>
                            <div class="col-12 col-sm-6">
                                <label class="form-label small text-secondary mb-1">分類</label>
                                <input type="text" @bind="Todo.Category" placeholder="工作、個人..." class="form-control form-control-sm" />
                            </div>
                            <div class="col-12 col-sm-6">
                                <label class="form-label small text-secondary mb-1">截止日期</label>
                                <input type="date" @bind="Todo.DueDate" class="form-control form-control-sm" />
                            </div>
                            <div class="col-12 col-sm-6">
                                <label class="form-label small text-secondary mb-1">預估時間（分鐘）</label>
                                <input type="number" @bind="Todo.EstimatedMinutes" placeholder="60" class="form-control form-control-sm" />
                            </div>
                        </div>

                        <div>
                            <label class="form-label small text-secondary mb-1">標籤（用逗號分隔）</label>
                            <input type="text" @bind="Todo.Tags" placeholder="重要, 緊急, 專案A" class="form-control form-control-sm" />
                        </div>

                        <div>
                            <label class="form-label small text-secondary mb-1">重複設定</label>
                            <select @bind="Todo.RecurringType" class="form-select form-select-sm">
                                <option value="">不重複</option>
                                <option value="Daily">每日</option>
                                <option value="Weekly">每週</option>
                                <option value="Monthly">每月</option>
                            </select>
                        </div>

                        <div>
                            <label class="form-label small text-secondary mb-1">備註</label>
                            <textarea @bind="Todo.Notes" rows="2" placeholder="額外備註..." class="form-control form-control-sm" style="resize: none;"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top">
                    <button @onclick="OnClose" class="btn btn-secondary btn-sm">
                        取消
                    </button>
                    <button @onclick="() => OnSave.InvokeAsync(Todo)" class="btn btn-primary btn-sm">
                        儲存
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public TodoItem Todo { get; set; } = new();
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<TodoItem> OnSave { get; set; }

    private bool ShowIconPicker { get; set; }

    private void ToggleIconPicker()
    {
        ShowIconPicker = !ShowIconPicker;
    }

    private void SelectIcon(string icon)
    {
        Todo.Icon = icon;
        ShowIconPicker = false;
    }
}

@* 篩選和排序組件 *@

<div class="mb-3 mb-sm-4 vstack gap-3">
    <div class="d-flex flex-column flex-sm-row gap-2">
        <div class="flex-fill position-relative">
            <input type="text" @bind="SearchQuery" @bind:event="oninput" @bind:after="OnSearchChanged"
                   placeholder="搜尋任務..." 
                   class="form-control form-control-sm ps-5" style="padding-left: 2.5rem;" />
            <svg class="position-absolute start-0 top-50 translate-middle-y ms-3" style="width: 1rem; height: 1rem; color: #6c757d;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
        </div>
        <button @onclick="OnToggleBatchActions" class="btn btn-outline-secondary btn-sm text-nowrap">
            批次操作
        </button>
    </div>

    <div class="d-flex flex-column flex-sm-row align-items-stretch align-items-sm-center gap-2 small">
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <span class="text-secondary text-nowrap me-1">篩選：</span>
            <button @onclick='() => OnFilterChanged("all")' class="btn btn-sm text-nowrap @(CurrentFilter == "all" ? "btn-primary" : "btn-outline-secondary")">
                全部 (@TotalCount)
            </button>
            <button @onclick='() => OnFilterChanged("active")' class="btn btn-sm text-nowrap @(CurrentFilter == "active" ? "btn-primary" : "btn-outline-secondary")">
                進行中 (@ActiveCount)
            </button>
            <button @onclick='() => OnFilterChanged("completed")' class="btn btn-sm text-nowrap @(CurrentFilter == "completed" ? "btn-primary" : "btn-outline-secondary")">
                已完成 (@CompletedCount)
            </button>
            <button @onclick='() => OnFilterChanged("starred")' class="btn btn-sm text-nowrap @(CurrentFilter == "starred" ? "btn-primary" : "btn-outline-secondary")">
                ⭐ 已加星號
            </button>
            <button @onclick='() => OnFilterChanged("overdue")' class="btn btn-sm text-nowrap @(CurrentFilter == "overdue" ? "btn-primary" : "btn-outline-secondary")">
                🔴 已逾期
            </button>
        </div>
        <select @bind="SortBy" @bind:after="OnSortChanged" class="form-select form-select-sm" style="min-width: 120px;">
            <option value="created">建立時間</option>
            <option value="duedate">截止日期</option>
            <option value="priority">優先級</option>
            <option value="title">標題</option>
        </select>
    </div>

    @if (ShowBatchActions && SelectedCount > 0)
    {
        <div class="d-flex align-items-center gap-2 p-3 bg-primary-subtle rounded">
            <span class="small text-primary-emphasis">已選擇 @SelectedCount 個任務</span>
            <button @onclick="OnBatchComplete" class="btn btn-success btn-sm">
                標記完成
            </button>
            <button @onclick="OnBatchDelete" class="btn btn-danger btn-sm">
                批次刪除
            </button>
            <button @onclick="OnClearSelection" class="btn btn-secondary btn-sm">
                取消選擇
            </button>
        </div>
    }
</div>

@code {
    [Parameter] public string SearchQuery { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> SearchQueryChanged { get; set; }
    [Parameter] public string CurrentFilter { get; set; } = "all";
    [Parameter] public EventCallback<string> CurrentFilterChanged { get; set; }
    [Parameter] public string SortBy { get; set; } = "created";
    [Parameter] public EventCallback<string> SortByChanged { get; set; }
    [Parameter] public bool ShowBatchActions { get; set; }
    [Parameter] public EventCallback<bool> ShowBatchActionsChanged { get; set; }
    [Parameter] public int TotalCount { get; set; }
    [Parameter] public int ActiveCount { get; set; }
    [Parameter] public int CompletedCount { get; set; }
    [Parameter] public int SelectedCount { get; set; }
    [Parameter] public EventCallback OnBatchComplete { get; set; }
    [Parameter] public EventCallback OnBatchDelete { get; set; }
    [Parameter] public EventCallback OnClearSelection { get; set; }
    [Parameter] public EventCallback OnFilterApplied { get; set; }

    private async Task OnSearchChanged()
    {
        await SearchQueryChanged.InvokeAsync(SearchQuery);
        await OnFilterApplied.InvokeAsync();
    }

    private async Task OnFilterChanged(string filter)
    {
        await CurrentFilterChanged.InvokeAsync(filter);
        await OnFilterApplied.InvokeAsync();
    }

    private async Task OnSortChanged()
    {
        await SortByChanged.InvokeAsync(SortBy);
        await OnFilterApplied.InvokeAsync();
    }

    private async Task OnToggleBatchActions()
    {
        await ShowBatchActionsChanged.InvokeAsync(!ShowBatchActions);
    }
}

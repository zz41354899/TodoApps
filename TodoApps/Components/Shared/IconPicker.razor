@* Icon 選擇器組件 *@

<div class="d-grid gap-2 p-3 bg-light rounded" style="grid-template-columns: repeat(8, 1fr);">
    @foreach (var icon in AvailableIcons)
    {
        <button @onclick="() => OnIconSelected.InvokeAsync(icon)" class="btn btn-light fs-4 p-2" style="transition: background-color 0.15s;" onmouseover="this.style.backgroundColor='#dee2e6'" onmouseout="this.style.backgroundColor='#f8f9fa'">@icon</button>
    }
</div>

@code {
    [Parameter] public EventCallback<string> OnIconSelected { get; set; }

    private string[] AvailableIcons = new[]
    {
        "📝", "✅", "📋", "📌", "⭐", "🎯", "💡", "🔥",
        "📱", "💻", "📧", "📞", "🏠", "🏢", "🛒", "🎓",
        "💪", "🎨", "📚", "✈️", "🚗", "🍕", "☕", "🎵",
        "⚡", "🌟", "🎉", "🔔", "📅", "⏰", "🎁", "🌈"
    };
}

@using TodoApps.Models

@* 單個任務項目組件 *@

<div class="@(IsOverdue ? "border-start border-danger border-3" : "")">
    <div class="d-flex align-items-start px-3 py-3 rounded @(Todo.IsCompleted ? "opacity-50" : "")" style="transition: background-color 0.15s;" onmouseover="this.style.backgroundColor='#f8f9fa'" onmouseout="this.style.backgroundColor='transparent'">
        @if (ShowBatchCheckbox)
        {
            <div class="flex-shrink-0 me-2">
                <input type="checkbox" checked="@IsSelected" @onchange="OnSelectChanged" class="form-check-input" />
            </div>
        }
        
        @if (Todo.SubTasks.Any())
        {
            <button @onclick="OnToggleExpand" class="btn btn-link btn-sm p-0 me-1 text-secondary" style="min-width: 1.25rem;">
                <svg style="width: 1rem; height: 1rem; transition: transform 0.15s; @(IsExpanded ? "transform: rotate(90deg);" : "")" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                </svg>
            </button>
        }
        else
        {
            <div class="flex-shrink-0 me-1" style="width: 1.25rem;"></div>
        }
        
        <div class="flex-shrink-0">
            <input type="checkbox" checked="@Todo.IsCompleted" @onchange="OnToggleComplete" class="form-check-input" style="cursor: pointer;" />
        </div>
        
        <div class="flex-fill ms-2 ms-sm-3 overflow-hidden">
            <div class="d-flex align-items-start">
                <button @onclick="OnIconClick" class="btn btn-link btn-sm p-0 me-2 fs-5 flex-shrink-0" style="transition: transform 0.15s;" onmouseover="this.style.transform='scale(1.1)'" onmouseout="this.style.transform='scale(1)'">@Todo.Icon</button>
                <div class="flex-fill overflow-hidden">
                    <div class="d-flex align-items-center gap-1 gap-sm-2 flex-wrap">
                        <p class="small mb-0 @(Todo.IsCompleted ? "text-decoration-line-through text-secondary" : "text-dark") text-break">
                            @Todo.Title
                        </p>
                        @if (Todo.IsStarred)
                        {
                            <span class="text-warning flex-shrink-0">⭐</span>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(Todo.Description))
                    {
                        <p class="small text-secondary mt-1 mb-0 text-break">@Todo.Description</p>
                    }
                    <div class="d-flex align-items-center gap-1 gap-sm-2 mt-1 flex-wrap">
                        <span class="d-inline-flex align-items-center small text-nowrap">
                            @GetPriorityIcon(Todo.Priority)
                        </span>
                        @if (Todo.DueDate.HasValue)
                        {
                            <span class="d-inline-flex align-items-center small @(IsOverdue ? "text-danger" : "text-secondary") text-nowrap">
                                <svg style="width: 0.75rem; height: 0.75rem;" class="me-1" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
                                </svg>
                                @Todo.DueDate.Value.ToString("MM/dd")
                            </span>
                        }
                        @if (!string.IsNullOrEmpty(Todo.Tags))
                        {
                            @foreach (var tag in Todo.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries))
                            {
                                <span class="badge bg-primary-subtle text-primary-emphasis text-nowrap">
                                    #@tag.Trim()
                                </span>
                            }
                        }
                        @if (Todo.SubTasks.Any())
                        {
                            <span class="small text-secondary text-nowrap">
                                ✓ @Todo.SubTasks.Count(s => s.IsCompleted)/@Todo.SubTasks.Count
                            </span>
                        }
                        @if (Todo.EstimatedMinutes > 0)
                        {
                            <span class="small text-secondary text-nowrap">
                                ⏱ @Todo.EstimatedMinutes 分鐘
                            </span>
                        }
                        @if (!string.IsNullOrEmpty(Todo.RecurringType))
                        {
                            <span class="small text-primary text-nowrap">
                                🔄 @GetRecurringText(Todo.RecurringType)
                            </span>
                        }
                    </div>
                </div>
                <div class="d-flex align-items-start gap-1 ms-1 ms-sm-2 flex-shrink-0 action-buttons" style="opacity: 0; transition: opacity 0.15s;">
                    <button @onclick="OnAddSubTask" class="btn btn-link btn-sm p-1 text-secondary" title="新增子任務" onmouseover="this.classList.add('text-primary')" onmouseout="this.classList.remove('text-primary')">
                        <svg style="width: 0.875rem; height: 0.875rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                        </svg>
                    </button>
                    <button @onclick="OnToggleStar" class="btn btn-link btn-sm p-1 text-secondary" title="加星號" onmouseover="this.classList.add('text-warning')" onmouseout="this.classList.remove('text-warning')">
                        <svg style="width: 0.875rem; height: 0.875rem;" fill="@(Todo.IsStarred ? "currentColor" : "none")" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                        </svg>
                    </button>
                    <button @onclick="OnEdit" class="btn btn-link btn-sm p-1 text-secondary" title="編輯" onmouseover="this.classList.add('text-dark')" onmouseout="this.classList.remove('text-dark')">
                        <svg style="width: 0.875rem; height: 0.875rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                        </svg>
                    </button>
                    <button @onclick="OnDelete" class="btn btn-link btn-sm p-1 text-secondary" title="刪除" onmouseover="this.classList.add('text-danger')" onmouseout="this.classList.remove('text-danger')">
                        <svg style="width: 0.875rem; height: 0.875rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    </div>
    
    @if (IsExpanded && Todo.SubTasks.Any())
    {
        <div class="ms-4 ms-sm-5 mt-1 vstack gap-1 border-start border-2 border-secondary-subtle ps-3 ps-sm-4">
            @foreach (var subTask in Todo.SubTasks)
            {
                <div class="d-flex align-items-start py-2 rounded @(subTask.IsCompleted ? "opacity-50" : "")" style="transition: background-color 0.15s;" onmouseover="this.style.backgroundColor='#f8f9fa'; this.querySelector('.action-buttons').style.opacity='1'" onmouseout="this.style.backgroundColor='transparent'; this.querySelector('.action-buttons').style.opacity='0'">
                    <div class="flex-shrink-0">
                        <input type="checkbox" checked="@subTask.IsCompleted" @onchange="() => OnSubTaskToggle.InvokeAsync(subTask.Id)" class="form-check-input form-check-input-sm" style="cursor: pointer;" />
                    </div>
                    <div class="flex-fill ms-2 overflow-hidden">
                        <p class="small mb-0 @(subTask.IsCompleted ? "text-decoration-line-through text-secondary" : "text-body") text-break">
                            @subTask.Icon @subTask.Title
                        </p>
                    </div>
                    <div class="d-flex align-items-center gap-1 ms-1 flex-shrink-0 action-buttons" style="opacity: 0; transition: opacity 0.15s;">
                        <button @onclick="() => OnSubTaskEdit.InvokeAsync(subTask)" class="btn btn-link btn-sm p-1 text-secondary" title="編輯" onmouseover="this.classList.add('text-dark')" onmouseout="this.classList.remove('text-dark')">
                            <svg style="width: 0.75rem; height: 0.75rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                            </svg>
                        </button>
                        <button @onclick="() => OnSubTaskDelete.InvokeAsync(subTask.Id)" class="btn btn-link btn-sm p-1 text-secondary" title="刪除" onmouseover="this.classList.add('text-danger')" onmouseout="this.classList.remove('text-danger')">
                            <svg style="width: 0.75rem; height: 0.75rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                            </svg>
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public TodoItem Todo { get; set; } = null!;
    [Parameter] public bool ShowBatchCheckbox { get; set; }
    [Parameter] public bool IsSelected { get; set; }
    [Parameter] public bool IsExpanded { get; set; }
    [Parameter] public EventCallback OnToggleComplete { get; set; }
    [Parameter] public EventCallback OnToggleExpand { get; set; }
    [Parameter] public EventCallback OnToggleStar { get; set; }
    [Parameter] public EventCallback OnIconClick { get; set; }
    [Parameter] public EventCallback OnEdit { get; set; }
    [Parameter] public EventCallback OnDelete { get; set; }
    [Parameter] public EventCallback OnAddSubTask { get; set; }
    [Parameter] public EventCallback OnSelectChanged { get; set; }
    [Parameter] public EventCallback<int> OnSubTaskToggle { get; set; }
    [Parameter] public EventCallback<TodoItem> OnSubTaskEdit { get; set; }
    [Parameter] public EventCallback<int> OnSubTaskDelete { get; set; }

    private bool IsOverdue => Todo.DueDate.HasValue && Todo.DueDate.Value < DateTime.Today && !Todo.IsCompleted;

    private string GetPriorityIcon(string? priority) => priority switch
    {
        "High" => "🔴 高",
        "Medium" => "🟡 中",
        "Low" => "🟢 低",
        _ => "🟡 中"
    };

    private string GetRecurringText(string? type) => type switch
    {
        "Daily" => "每日",
        "Weekly" => "每週",
        "Monthly" => "每月",
        _ => ""
    };
}

@using TodoApps.Models

@* 單個任務項目組件 *@

<div class="@(IsOverdue ? "border-l-2 border-red-500" : "")">
    <div class="group flex items-start px-2 sm:px-3 py-2 hover:bg-gray-50 rounded transition-colors @(Todo.IsCompleted ? "opacity-50" : "")">
        @if (ShowBatchCheckbox)
        {
            <div class="flex-shrink-0 pt-0.5 mr-2">
                <input type="checkbox" checked="@IsSelected" @onchange="OnSelectChanged" class="h-4 w-4 text-blue-600 border-gray-300 rounded" />
            </div>
        }
        
        @if (Todo.SubTasks.Any())
        {
            <button @onclick="OnToggleExpand" class="flex-shrink-0 pt-0.5 mr-1 text-gray-400 hover:text-gray-600">
                <svg class="h-4 w-4 transition-transform @(IsExpanded ? "rotate-90" : "")" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                </svg>
            </button>
        }
        else
        {
            <div class="flex-shrink-0 w-5 mr-1"></div>
        }
        
        <div class="flex-shrink-0 pt-0.5">
            <input type="checkbox" checked="@Todo.IsCompleted" @onchange="OnToggleComplete" class="h-4 w-4 text-gray-900 border-gray-300 rounded cursor-pointer" />
        </div>
        
        <div class="flex-1 ml-2 sm:ml-3 min-w-0">
            <div class="flex items-start">
                <button @onclick="OnIconClick" class="text-lg sm:text-xl mr-2 hover:scale-110 transition-transform flex-shrink-0">@Todo.Icon</button>
                <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-1 sm:gap-2 flex-wrap">
                        <p class="text-sm @(Todo.IsCompleted ? "line-through text-gray-500" : "text-gray-900") break-words">
                            @Todo.Title
                        </p>
                        @if (Todo.IsStarred)
                        {
                            <span class="text-yellow-500 flex-shrink-0">⭐</span>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(Todo.Description))
                    {
                        <p class="text-xs text-gray-500 mt-0.5 break-words">@Todo.Description</p>
                    }
                    <div class="flex items-center gap-1 sm:gap-2 mt-1 flex-wrap">
                        <span class="inline-flex items-center text-xs whitespace-nowrap">
                            @GetPriorityIcon(Todo.Priority)
                        </span>
                        @if (Todo.DueDate.HasValue)
                        {
                            <span class="inline-flex items-center text-xs @(IsOverdue ? "text-red-600" : "text-gray-500") whitespace-nowrap">
                                <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
                                </svg>
                                @Todo.DueDate.Value.ToString("MM/dd")
                            </span>
                        }
                        @if (!string.IsNullOrEmpty(Todo.Tags))
                        {
                            @foreach (var tag in Todo.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries))
                            {
                                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs bg-blue-100 text-blue-800 whitespace-nowrap">
                                    #@tag.Trim()
                                </span>
                            }
                        }
                        @if (Todo.SubTasks.Any())
                        {
                            <span class="text-xs text-gray-500 whitespace-nowrap">
                                ✓ @Todo.SubTasks.Count(s => s.IsCompleted)/@Todo.SubTasks.Count
                            </span>
                        }
                        @if (Todo.EstimatedMinutes > 0)
                        {
                            <span class="text-xs text-gray-500 whitespace-nowrap">
                                ⏱ @Todo.EstimatedMinutes 分鐘
                            </span>
                        }
                        @if (!string.IsNullOrEmpty(Todo.RecurringType))
                        {
                            <span class="text-xs text-purple-600 whitespace-nowrap">
                                🔄 @GetRecurringText(Todo.RecurringType)
                            </span>
                        }
                    </div>
                </div>
                <div class="flex items-center gap-0.5 sm:gap-1 opacity-0 group-hover:opacity-100 transition-opacity ml-1 sm:ml-2 flex-shrink-0">
                    <button @onclick="OnAddSubTask" class="p-1 text-gray-400 hover:text-blue-600" title="新增子任務">
                        <svg class="h-3 w-3 sm:h-4 sm:w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                        </svg>
                    </button>
                    <button @onclick="OnToggleStar" class="p-1 text-gray-400 hover:text-yellow-500" title="加星號">
                        <svg class="h-3 w-3 sm:h-4 sm:w-4" fill="@(Todo.IsStarred ? "currentColor" : "none")" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                        </svg>
                    </button>
                    <button @onclick="OnEdit" class="p-1 text-gray-400 hover:text-gray-600" title="編輯">
                        <svg class="h-3 w-3 sm:h-4 sm:w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                        </svg>
                    </button>
                    <button @onclick="OnDelete" class="p-1 text-gray-400 hover:text-red-600" title="刪除">
                        <svg class="h-3 w-3 sm:h-4 sm:w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    </div>
    
    @if (IsExpanded && Todo.SubTasks.Any())
    {
        <div class="ml-8 sm:ml-12 mt-1 space-y-1 border-l-2 border-gray-200 pl-3 sm:pl-4">
            @foreach (var subTask in Todo.SubTasks)
            {
                <div class="group flex items-start py-1.5 hover:bg-gray-50 rounded transition-colors @(subTask.IsCompleted ? "opacity-50" : "")">
                    <div class="flex-shrink-0 pt-0.5">
                        <input type="checkbox" checked="@subTask.IsCompleted" @onchange="() => OnSubTaskToggle.InvokeAsync(subTask.Id)" class="h-3.5 w-3.5 text-gray-900 border-gray-300 rounded cursor-pointer" />
                    </div>
                    <div class="flex-1 ml-2 min-w-0">
                        <p class="text-sm @(subTask.IsCompleted ? "line-through text-gray-500" : "text-gray-700") break-words">
                            @subTask.Icon @subTask.Title
                        </p>
                    </div>
                    <div class="flex items-center gap-0.5 opacity-0 group-hover:opacity-100 transition-opacity ml-1 flex-shrink-0">
                        <button @onclick="() => OnSubTaskEdit.InvokeAsync(subTask)" class="p-1 text-gray-400 hover:text-gray-600" title="編輯">
                            <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                            </svg>
                        </button>
                        <button @onclick="() => OnSubTaskDelete.InvokeAsync(subTask.Id)" class="p-1 text-gray-400 hover:text-red-600" title="刪除">
                            <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                            </svg>
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public TodoItem Todo { get; set; } = null!;
    [Parameter] public bool ShowBatchCheckbox { get; set; }
    [Parameter] public bool IsSelected { get; set; }
    [Parameter] public bool IsExpanded { get; set; }
    [Parameter] public EventCallback OnToggleComplete { get; set; }
    [Parameter] public EventCallback OnToggleExpand { get; set; }
    [Parameter] public EventCallback OnToggleStar { get; set; }
    [Parameter] public EventCallback OnIconClick { get; set; }
    [Parameter] public EventCallback OnEdit { get; set; }
    [Parameter] public EventCallback OnDelete { get; set; }
    [Parameter] public EventCallback OnAddSubTask { get; set; }
    [Parameter] public EventCallback OnSelectChanged { get; set; }
    [Parameter] public EventCallback<int> OnSubTaskToggle { get; set; }
    [Parameter] public EventCallback<TodoItem> OnSubTaskEdit { get; set; }
    [Parameter] public EventCallback<int> OnSubTaskDelete { get; set; }

    private bool IsOverdue => Todo.DueDate.HasValue && Todo.DueDate.Value < DateTime.Today && !Todo.IsCompleted;

    private string GetPriorityIcon(string? priority) => priority switch
    {
        "High" => "🔴 高",
        "Medium" => "🟡 中",
        "Low" => "🟢 低",
        _ => "🟡 中"
    };

    private string GetRecurringText(string? type) => type switch
    {
        "Daily" => "每日",
        "Weekly" => "每週",
        "Monthly" => "每月",
        _ => ""
    };
}

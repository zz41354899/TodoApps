@page "/"
@using TodoApps.Models
@using TodoApps.Services
@using TodoApps.Components.Shared
@inject TodoService TodoService
@rendermode InteractiveServer

<PageTitle>Todo</PageTitle>

<div class="d-flex vh-100 bg-white overflow-hidden">
    <aside class="d-none d-lg-block border-end border-secondary-subtle" style="width: 240px;">
        <Sidebar />
    </aside>

    <main class="flex-fill overflow-auto bg-white">
        <div class="container" style="max-width: 800px;">
            <div class="mb-3 mb-sm-4 pt-3 pt-sm-4 pt-md-5">
                <h1 class="display-5 fw-bold text-dark mb-2">📋 Todo</h1>
                <p class="small text-secondary">@DateTime.Now.ToString("yyyy年MM月dd日 dddd")</p>
            </div>

            <TodoFilters 
                @bind-SearchQuery="searchQuery"
                @bind-CurrentFilter="currentFilter"
                @bind-SortBy="sortBy"
                @bind-ShowBatchActions="showBatchActions"
                TotalCount="@allTodos.Count"
                ActiveCount="@allTodos.Count(t => !t.IsCompleted)"
                CompletedCount="@allTodos.Count(t => t.IsCompleted)"
                SelectedCount="@selectedTodos.Count"
                OnBatchComplete="BatchComplete"
                OnBatchDelete="BatchDelete"
                OnClearSelection="ClearSelection"
                OnFilterApplied="ApplyFilters" />

            @if (isLoading)
            {
                <div class="d-flex justify-content-center align-items-center" style="height: 16rem;">
                    <div class="spinner-border text-dark" role="status">
                        <span class="visually-hidden">載入中...</span>
                    </div>
                </div>
            }
            else
            {
                <div class="vstack gap-1">
                    <button @onclick="ShowAddModal" class="btn btn-light w-100 d-flex align-items-center justify-content-start px-3 py-2 text-start">
                        <span class="fs-5 me-2">+</span>
                        <span class="small">新增任務</span>
                    </button>

                    @if (showBatchActions)
                    {
                        <div class="d-flex align-items-center px-3 py-2 bg-light rounded">
                            <input type="checkbox" @onchange="ToggleSelectAll" checked="@(selectedTodos.Count == filteredTodos.Count && filteredTodos.Any())" class="form-check-input me-2" />
                            <span class="small text-secondary">全選</span>
                        </div>
                    }

                    @if (filteredTodos.Count == 0)
                    {
                        <div class="text-center py-5">
                            <p class="small text-muted">還沒有任務</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var todo in filteredTodos)
                        {
                            <TodoListItem 
                                Todo="@todo"
                                ShowBatchCheckbox="@showBatchActions"
                                IsSelected="@selectedTodos.Contains(todo.Id)"
                                IsExpanded="@expandedTodos.Contains(todo.Id)"
                                OnToggleComplete="() => ToggleComplete(todo.Id)"
                                OnToggleExpand="() => ToggleExpand(todo.Id)"
                                OnToggleStar="() => ToggleStar(todo.Id)"
                                OnIconClick="() => ShowIconPicker(todo)"
                                OnEdit="() => ShowEditModal(todo)"
                                OnDelete="() => DeleteTodo(todo.Id)"
                                OnAddSubTask="() => ShowAddSubTaskModal(todo)"
                                OnSelectChanged="() => ToggleSelect(todo.Id)"
                                OnSubTaskToggle="ToggleComplete"
                                OnSubTaskEdit="ShowEditModal"
                                OnSubTaskDelete="DeleteTodo" />
                        }
                    }
                </div>
            }
        </div>
    </main>
</div>

<TodoModal 
    IsVisible="@showModal"
    Todo="@editingTodo"
    OnClose="CloseModal"
    OnSave="SaveTodo" />

@if (showIconPickerModal)
{
    <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);" @onclick="() => showIconPickerModal = false">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h5 class="modal-title">選擇圖示</h5>
                    <button type="button" class="btn-close" @onclick="() => showIconPickerModal = false"></button>
                </div>
                <div class="modal-body">
                    <IconPicker OnIconSelected="UpdateTodoIcon" />
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<TodoItem> allTodos = new();
    private List<TodoItem> filteredTodos = new();
    private bool isLoading = true;
    private bool showModal = false;
    private bool showIconPickerModal = false;
    private bool showBatchActions = false;
    private TodoItem editingTodo = new();
    private TodoItem? iconEditingTodo = null;
    private HashSet<int> selectedTodos = new();
    private HashSet<int> expandedTodos = new();
    private string searchQuery = string.Empty;
    private string currentFilter = "all";
    private string sortBy = "created";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        allTodos = await TodoService.GetAllTodosAsync();
        ApplyFilters();
        isLoading = false;
    }

    private void ApplyFilters()
    {
        var query = allTodos.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            query = query.Where(t => t.Title.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                                     (t.Description?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false));
        }

        query = currentFilter switch
        {
            "active" => query.Where(t => !t.IsCompleted),
            "completed" => query.Where(t => t.IsCompleted),
            "starred" => query.Where(t => t.IsStarred),
            "overdue" => query.Where(t => t.DueDate.HasValue && t.DueDate.Value < DateTime.Today && !t.IsCompleted),
            _ => query
        };

        filteredTodos = sortBy switch
        {
            "duedate" => query.OrderBy(t => t.DueDate ?? DateTime.MaxValue).ToList(),
            "priority" => query.OrderByDescending(t => t.Priority == "High" ? 3 : t.Priority == "Medium" ? 2 : 1).ToList(),
            "title" => query.OrderBy(t => t.Title).ToList(),
            _ => query.OrderByDescending(t => t.CreatedAt).ToList()
        };
    }


    private void ShowAddModal()
    {
        editingTodo = new TodoItem { Priority = "Medium", Icon = "📝", DueDate = DateTime.Today.AddDays(1) };
        showModal = true;
    }

    private void ShowAddSubTaskModal(TodoItem parent)
    {
        editingTodo = new TodoItem { Priority = "Medium", Icon = "📝", ParentId = parent.Id };
        showModal = true;
    }

    private void ShowEditModal(TodoItem todo)
    {
        editingTodo = new TodoItem
        {
            Id = todo.Id,
            Title = todo.Title,
            Description = todo.Description,
            Priority = todo.Priority,
            Category = todo.Category,
            IsCompleted = todo.IsCompleted,
            Icon = todo.Icon,
            DueDate = todo.DueDate,
            Tags = todo.Tags,
            IsStarred = todo.IsStarred,
            RecurringType = todo.RecurringType,
            RecurringInterval = todo.RecurringInterval,
            EstimatedMinutes = todo.EstimatedMinutes,
            AssignedTo = todo.AssignedTo,
            Notes = todo.Notes,
            ParentId = todo.ParentId
        };
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        editingTodo = new();
    }

    private async Task SaveTodo(TodoItem todo)
    {
        if (string.IsNullOrWhiteSpace(todo.Title)) return;

        if (todo.Id > 0)
            await TodoService.UpdateTodoAsync(todo);
        else
            await TodoService.CreateTodoAsync(todo);

        await LoadData();
        CloseModal();
    }

    private async Task ToggleComplete(int id)
    {
        await TodoService.ToggleCompleteAsync(id);
        await LoadData();
    }

    private async Task DeleteTodo(int id)
    {
        await TodoService.DeleteTodoAsync(id);
        selectedTodos.Remove(id);
        await LoadData();
    }

    private async Task ToggleStar(int id)
    {
        var todo = allTodos.FirstOrDefault(t => t.Id == id);
        if (todo != null)
        {
            todo.IsStarred = !todo.IsStarred;
            await TodoService.UpdateTodoAsync(todo);
            await LoadData();
        }
    }

    private void ShowIconPicker(TodoItem todo)
    {
        iconEditingTodo = todo;
        showIconPickerModal = true;
    }

    private async Task UpdateTodoIcon(string icon)
    {
        if (iconEditingTodo != null)
        {
            iconEditingTodo.Icon = icon;
            await TodoService.UpdateTodoAsync(iconEditingTodo);
            await LoadData();
        }
        showIconPickerModal = false;
        iconEditingTodo = null;
    }

    private void ToggleExpand(int todoId)
    {
        if (expandedTodos.Contains(todoId))
            expandedTodos.Remove(todoId);
        else
            expandedTodos.Add(todoId);
    }

    private void ToggleSelect(int id)
    {
        if (selectedTodos.Contains(id))
            selectedTodos.Remove(id);
        else
            selectedTodos.Add(id);
    }

    private void ToggleSelectAll()
    {
        if (selectedTodos.Count == filteredTodos.Count)
            selectedTodos.Clear();
        else
        {
            selectedTodos.Clear();
            foreach (var todo in filteredTodos)
                selectedTodos.Add(todo.Id);
        }
    }

    private async Task BatchComplete()
    {
        foreach (var id in selectedTodos)
            await ToggleComplete(id);
        selectedTodos.Clear();
    }

    private async Task BatchDelete()
    {
        foreach (var id in selectedTodos.ToList())
            await DeleteTodo(id);
        selectedTodos.Clear();
    }

    private void ClearSelection()
    {
        selectedTodos.Clear();
    }
}

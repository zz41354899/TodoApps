@page "/"
@using TodoApps.Models
@using TodoApps.Services
@inject TodoService TodoService
@rendermode InteractiveServer

<PageTitle>Todo</PageTitle>

<div class="flex h-screen bg-white overflow-hidden">
    <aside class="w-60 flex-shrink-0 border-r border-gray-200">
        <Sidebar />
    </aside>

    <main class="flex-1 overflow-y-auto bg-white">
        <div class="max-w-4xl mx-auto px-16 py-12">
            <div class="mb-6">
                <h1 class="text-4xl font-bold text-gray-900 mb-2">📋 Todo</h1>
                <p class="text-sm text-gray-500">@DateTime.Now.ToString("yyyy年MM月dd日 dddd")</p>
            </div>

            <div class="mb-6 space-y-3">
                <div class="flex items-center space-x-2">
                    <div class="flex-1 relative">
                        <input type="text" @bind="searchQuery" @bind:event="oninput" @onkeyup="FilterTodos" placeholder="搜尋任務..." class="w-full pl-9 pr-4 py-2 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" />
                        <svg class="absolute left-3 top-2.5 h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                        </svg>
                    </div>
                    <button @onclick="() => showBatchActions = !showBatchActions" class="px-3 py-2 text-sm border border-gray-300 rounded-lg hover:bg-gray-50">
                        批次操作
                    </button>
                </div>

                <div class="flex items-center space-x-2 text-sm">
                    <span class="text-gray-500">篩選：</span>
                    <button @onclick='() => SetFilter("all")' class="px-3 py-1 rounded @(currentFilter == "all" ? "bg-gray-900 text-white" : "bg-gray-100 text-gray-700 hover:bg-gray-200")">
                        全部 (@allTodos.Count)
                    </button>
                    <button @onclick='() => SetFilter("active")' class="px-3 py-1 rounded @(currentFilter == "active" ? "bg-gray-900 text-white" : "bg-gray-100 text-gray-700 hover:bg-gray-200")">
                        進行中 (@allTodos.Count(t => !t.IsCompleted))
                    </button>
                    <button @onclick='() => SetFilter("completed")' class="px-3 py-1 rounded @(currentFilter == "completed" ? "bg-gray-900 text-white" : "bg-gray-100 text-gray-700 hover:bg-gray-200")">
                        已完成 (@allTodos.Count(t => t.IsCompleted))
                    </button>
                    <button @onclick='() => SetFilter("starred")' class="px-3 py-1 rounded @(currentFilter == "starred" ? "bg-gray-900 text-white" : "bg-gray-100 text-gray-700 hover:bg-gray-200")">
                        ⭐ 已加星號
                    </button>
                    <button @onclick='() => SetFilter("overdue")' class="px-3 py-1 rounded @(currentFilter == "overdue" ? "bg-gray-900 text-white" : "bg-gray-100 text-gray-700 hover:bg-gray-200")">
                        🔴 已逾期
                    </button>
                    <div class="flex-1"></div>
                    <select @bind="sortBy" @bind:after="SortTodos" class="px-3 py-1 text-sm border border-gray-300 rounded">
                        <option value="created">建立時間</option>
                        <option value="duedate">截止日期</option>
                        <option value="priority">優先級</option>
                        <option value="title">標題</option>
                    </select>
                </div>

                @if (showBatchActions && selectedTodos.Any())
                {
                    <div class="flex items-center space-x-2 p-3 bg-blue-50 rounded-lg">
                        <span class="text-sm text-blue-900">已選擇 @selectedTodos.Count 個任務</span>
                        <button @onclick="BatchComplete" class="px-3 py-1 text-sm bg-green-600 text-white rounded hover:bg-green-700">
                            標記完成
                        </button>
                        <button @onclick="BatchDelete" class="px-3 py-1 text-sm bg-red-600 text-white rounded hover:bg-red-700">
                            批次刪除
                        </button>
                        <button @onclick="ClearSelection" class="px-3 py-1 text-sm bg-gray-600 text-white rounded hover:bg-gray-700">
                            取消選擇
                        </button>
                    </div>
                }
            </div>

            @if (isLoading)
            {
                <div class="flex justify-center items-center h-64">
                    <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-gray-900"></div>
                </div>
            }
            else
            {

                <div class="space-y-1">
                    <button @onclick="ShowAddModal" class="group w-full flex items-center px-3 py-2 text-sm text-gray-500 hover:bg-gray-50 rounded transition-colors">
                        <span class="text-lg mr-2">+</span>
                        <span>新增任務</span>
                    </button>

                    @if (showBatchActions)
                    {
                        <div class="flex items-center px-3 py-2 bg-gray-50 rounded">
                            <input type="checkbox" @onchange="ToggleSelectAll" checked="@(selectedTodos.Count == filteredTodos.Count && filteredTodos.Any())" class="h-4 w-4 text-blue-600 border-gray-300 rounded" />
                            <span class="ml-3 text-sm text-gray-600">全選</span>
                        </div>
                    }

                    @if (filteredTodos.Count == 0)
                    {
                        <div class="text-center py-20">
                            <p class="text-sm text-gray-400">還沒有任務</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var todo in filteredTodos)
                        {
                            <div class="group flex items-start px-3 py-2 hover:bg-gray-50 rounded transition-colors @(todo.IsCompleted ? "opacity-50" : "") @(IsOverdue(todo) ? "border-l-2 border-red-500" : "")">
                                @if (showBatchActions)
                                {
                                    <div class="flex-shrink-0 pt-0.5 mr-2">
                                        <input type="checkbox" checked="@selectedTodos.Contains(todo.Id)" @onchange="() => ToggleSelect(todo.Id)" class="h-4 w-4 text-blue-600 border-gray-300 rounded" />
                                    </div>
                                }
                                <div class="flex-shrink-0 pt-0.5">
                                    <input type="checkbox" checked="@todo.IsCompleted" @onchange="() => ToggleComplete(todo.Id)" class="h-4 w-4 text-gray-900 border-gray-300 rounded cursor-pointer" />
                                </div>
                                <div class="flex-1 ml-3 min-w-0">
                                    <div class="flex items-start">
                                        <button @onclick="() => ShowIconPicker(todo)" class="text-xl mr-2 hover:scale-110 transition-transform">@todo.Icon</button>
                                        <div class="flex-1">
                                            <div class="flex items-center space-x-2">
                                                <p class="text-sm @(todo.IsCompleted ? "line-through text-gray-500" : "text-gray-900")">
                                                    @todo.Title
                                                </p>
                                                @if (todo.IsStarred)
                                                {
                                                    <span class="text-yellow-500">⭐</span>
                                                }
                                            </div>
                                            @if (!string.IsNullOrEmpty(todo.Description))
                                            {
                                                <p class="text-xs text-gray-500 mt-0.5">@todo.Description</p>
                                            }
                                            <div class="flex items-center space-x-2 mt-1">
                                                @if (todo.DueDate.HasValue)
                                                {
                                                    <span class="inline-flex items-center text-xs @(IsOverdue(todo) ? "text-red-600" : "text-gray-500")">
                                                        <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                                            <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
                                                        </svg>
                                                        @todo.DueDate.Value.ToString("MM/dd")
                                                    </span>
                                                }
                                                @if (!string.IsNullOrEmpty(todo.Tags))
                                                {
                                                    @foreach (var tag in todo.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                                    {
                                                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs bg-blue-100 text-blue-800">
                                                            #@tag.Trim()
                                                        </span>
                                                    }
                                                }
                                                @if (todo.SubTasksTotal > 0)
                                                {
                                                    <span class="text-xs text-gray-500">
                                                        ✓ @todo.SubTasksCompleted/@todo.SubTasksTotal
                                                    </span>
                                                }
                                                @if (todo.EstimatedMinutes > 0)
                                                {
                                                    <span class="text-xs text-gray-500">
                                                        ⏱ @todo.EstimatedMinutes 分鐘
                                                    </span>
                                                }
                                                @if (!string.IsNullOrEmpty(todo.RecurringType))
                                                {
                                                    <span class="text-xs text-purple-600">
                                                        🔄 @GetRecurringText(todo.RecurringType)
                                                    </span>
                                                }
                                            </div>
                                        </div>
                                        <div class="flex items-center space-x-1 opacity-0 group-hover:opacity-100 transition-opacity ml-2">
                                            <button @onclick="() => ToggleStar(todo.Id)" class="p-1 text-gray-400 hover:text-yellow-500" title="加星號">
                                                <svg class="h-4 w-4" fill="@(todo.IsStarred ? "currentColor" : "none")" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                                                </svg>
                                            </button>
                                            <button @onclick="() => ShowEditModal(todo)" class="p-1 text-gray-400 hover:text-gray-600" title="編輯">
                                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                                </svg>
                                            </button>
                                            <button @onclick="() => DeleteTodo(todo.Id)" class="p-1 text-gray-400 hover:text-red-600" title="刪除">
                                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                                </svg>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
            }
        </div>
    </main>
</div>

@if (showModal)
{
    <div class="fixed z-50 inset-0 overflow-y-auto" @onclick="CloseModal">
        <div class="flex items-center justify-center min-h-screen p-4">
            <div class="fixed inset-0 bg-black bg-opacity-25"></div>
            <div class="relative bg-white rounded-lg shadow-xl max-w-2xl w-full" @onclick:stopPropagation="true">
                <div class="p-6">
                    <div class="space-y-4">
                        <div class="flex items-center space-x-3">
                            <button @onclick="() => showIconPicker = !showIconPicker" class="text-3xl hover:bg-gray-100 rounded p-2">
                                @editingTodo.Icon
                            </button>
                            <input type="text" @bind="editingTodo.Title" placeholder="任務標題" class="flex-1 text-lg font-medium border-0 focus:ring-0 focus:outline-none" />
                            <button @onclick="() => editingTodo.IsStarred = !editingTodo.IsStarred" class="text-2xl hover:scale-110 transition-transform">
                                @(editingTodo.IsStarred ? "⭐" : "☆")
                            </button>
                        </div>
                        @if (showIconPicker)
                        {
                            <div class="grid grid-cols-8 gap-2 p-3 bg-gray-50 rounded">
                                @foreach (var icon in availableIcons)
                                {
                                    <button @onclick="() => SelectIcon(icon)" class="text-2xl hover:bg-gray-200 rounded p-2">@icon</button>
                                }
                            </div>
                        }
                        <textarea @bind="editingTodo.Description" rows="3" placeholder="新增描述..." class="w-full text-sm border-0 focus:ring-0 focus:outline-none resize-none"></textarea>
                        
                        <div class="grid grid-cols-2 gap-3">
                            <div>
                                <label class="block text-xs text-gray-500 mb-1">優先級</label>
                                <select @bind="editingTodo.Priority" class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm">
                                    <option value="Low">🟢 低</option>
                                    <option value="Medium">🟡 中</option>
                                    <option value="High">🔴 高</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-xs text-gray-500 mb-1">分類</label>
                                <input type="text" @bind="editingTodo.Category" placeholder="工作、個人..." class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm" />
                            </div>
                            <div>
                                <label class="block text-xs text-gray-500 mb-1">截止日期</label>
                                <input type="date" @bind="editingTodo.DueDate" class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm" />
                            </div>
                            <div>
                                <label class="block text-xs text-gray-500 mb-1">預估時間（分鐘）</label>
                                <input type="number" @bind="editingTodo.EstimatedMinutes" placeholder="60" class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm" />
                            </div>
                        </div>

                        <div>
                            <label class="block text-xs text-gray-500 mb-1">標籤（用逗號分隔）</label>
                            <input type="text" @bind="editingTodo.Tags" placeholder="重要, 緊急, 專案A" class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm" />
                        </div>

                        <div>
                            <label class="block text-xs text-gray-500 mb-1">重複設定</label>
                            <select @bind="editingTodo.RecurringType" class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm">
                                <option value="">不重複</option>
                                <option value="Daily">每日</option>
                                <option value="Weekly">每週</option>
                                <option value="Monthly">每月</option>
                            </select>
                        </div>

                        <div>
                            <label class="block text-xs text-gray-500 mb-1">子任務進度</label>
                            <div class="flex items-center space-x-2">
                                <input type="number" @bind="editingTodo.SubTasksCompleted" placeholder="0" class="w-20 border border-gray-300 rounded px-3 py-1.5 text-sm" />
                                <span class="text-gray-500">/</span>
                                <input type="number" @bind="editingTodo.SubTasksTotal" placeholder="0" class="w-20 border border-gray-300 rounded px-3 py-1.5 text-sm" />
                                <span class="text-xs text-gray-500">已完成/總數</span>
                            </div>
                        </div>

                        <div>
                            <label class="block text-xs text-gray-500 mb-1">備註</label>
                            <textarea @bind="editingTodo.Notes" rows="2" placeholder="額外備註..." class="w-full border border-gray-300 rounded px-3 py-1.5 text-sm resize-none"></textarea>
                        </div>
                    </div>
                </div>
                <div class="border-t border-gray-200 px-6 py-3 flex justify-end space-x-2">
                    <button @onclick="CloseModal" class="px-4 py-2 text-sm text-gray-600 hover:bg-gray-100 rounded">
                        取消
                    </button>
                    <button @onclick="SaveTodo" class="px-4 py-2 text-sm text-white bg-blue-600 hover:bg-blue-700 rounded">
                        儲存
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (showIconPickerModal)
{
    <div class="fixed z-50 inset-0 overflow-y-auto" @onclick="() => showIconPickerModal = false">
        <div class="flex items-center justify-center min-h-screen p-4">
            <div class="fixed inset-0 bg-black bg-opacity-25"></div>
            <div class="relative bg-white rounded-lg shadow-xl max-w-md w-full p-6" @onclick:stopPropagation="true">
                <h3 class="text-lg font-semibold mb-4">選擇圖示</h3>
                <div class="grid grid-cols-6 gap-3">
                    @foreach (var icon in availableIcons)
                    {
                        <button @onclick="() => UpdateTodoIcon(icon)" class="text-3xl hover:bg-gray-100 rounded p-3">@icon</button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<TodoItem> allTodos = new();
    private List<TodoItem> filteredTodos = new();
    private Dictionary<string, int> statistics = new();
    private bool isLoading = true;
    private bool showModal = false;
    private bool showIconPicker = false;
    private bool showIconPickerModal = false;
    private bool showBatchActions = false;
    private TodoItem editingTodo = new();
    private TodoItem? iconEditingTodo = null;
    private HashSet<int> selectedTodos = new();
    private string searchQuery = string.Empty;
    private string currentFilter = "all";
    private string sortBy = "created";

    private string[] availableIcons = new[]
    {
        "📝", "✅", "📋", "📌", "⭐", "🎯", "💡", "🔥",
        "📱", "💻", "📧", "📞", "🏠", "🏢", "🛒", "🎓",
        "💪", "🎨", "📚", "✈️", "🚗", "🍕", "☕", "🎵",
        "⚡", "🌟", "🎉", "🔔", "📅", "⏰", "🎁", "🌈"
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        allTodos = await TodoService.GetAllTodosAsync();
        FilterTodos();
        statistics = await TodoService.GetStatisticsAsync();
        isLoading = false;
    }

    private void ShowAddModal()
    {
        editingTodo = new TodoItem { Priority = "Medium", Icon = "📝", DueDate = DateTime.Today.AddDays(1) };
        showModal = true;
        showIconPicker = false;
    }

    private void FilterTodos()
    {
        var query = allTodos.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            query = query.Where(t => t.Title.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                                     (t.Description?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false));
        }

        query = currentFilter switch
        {
            "active" => query.Where(t => !t.IsCompleted),
            "completed" => query.Where(t => t.IsCompleted),
            "starred" => query.Where(t => t.IsStarred),
            "overdue" => query.Where(t => t.DueDate.HasValue && t.DueDate.Value < DateTime.Today && !t.IsCompleted),
            _ => query
        };

        filteredTodos = sortBy switch
        {
            "duedate" => query.OrderBy(t => t.DueDate ?? DateTime.MaxValue).ToList(),
            "priority" => query.OrderByDescending(t => t.Priority == "High" ? 3 : t.Priority == "Medium" ? 2 : 1).ToList(),
            "title" => query.OrderBy(t => t.Title).ToList(),
            _ => query.OrderByDescending(t => t.CreatedAt).ToList()
        };
    }

    private void SetFilter(string filter)
    {
        currentFilter = filter;
        FilterTodos();
    }

    private void SortTodos()
    {
        FilterTodos();
    }

    private bool IsOverdue(TodoItem todo)
    {
        return todo.DueDate.HasValue && todo.DueDate.Value < DateTime.Today && !todo.IsCompleted;
    }

    private string GetRecurringText(string? type)
    {
        return type switch
        {
            "Daily" => "每日",
            "Weekly" => "每週",
            "Monthly" => "每月",
            _ => ""
        };
    }

    private void ToggleSelect(int id)
    {
        if (selectedTodos.Contains(id))
            selectedTodos.Remove(id);
        else
            selectedTodos.Add(id);
    }

    private void ToggleSelectAll()
    {
        if (selectedTodos.Count == filteredTodos.Count)
            selectedTodos.Clear();
        else
        {
            selectedTodos.Clear();
            foreach (var todo in filteredTodos)
                selectedTodos.Add(todo.Id);
        }
    }

    private async Task BatchComplete()
    {
        foreach (var id in selectedTodos)
        {
            await ToggleComplete(id);
        }
        selectedTodos.Clear();
    }

    private async Task BatchDelete()
    {
        foreach (var id in selectedTodos.ToList())
        {
            await DeleteTodo(id);
        }
        selectedTodos.Clear();
    }

    private void ClearSelection()
    {
        selectedTodos.Clear();
    }

    private async Task ToggleStar(int id)
    {
        var todo = allTodos.FirstOrDefault(t => t.Id == id);
        if (todo != null)
        {
            todo.IsStarred = !todo.IsStarred;
            await TodoService.UpdateTodoAsync(todo);
            await LoadData();
        }
    }

    private void ShowIconPicker(TodoItem todo)
    {
        iconEditingTodo = todo;
        showIconPickerModal = true;
    }

    private async Task UpdateTodoIcon(string icon)
    {
        if (iconEditingTodo != null)
        {
            iconEditingTodo.Icon = icon;
            await TodoService.UpdateTodoAsync(iconEditingTodo);
            await LoadData();
        }
        showIconPickerModal = false;
        iconEditingTodo = null;
    }

    private void SelectIcon(string icon)
    {
        editingTodo.Icon = icon;
        showIconPicker = false;
    }

    private void ShowEditModal(TodoItem todo)
    {
        editingTodo = new TodoItem
        {
            Id = todo.Id,
            Title = todo.Title,
            Description = todo.Description,
            Priority = todo.Priority,
            Category = todo.Category,
            IsCompleted = todo.IsCompleted,
            Icon = todo.Icon
        };
        showModal = true;
        showIconPicker = false;
    }

    private void CloseModal()
    {
        showModal = false;
        showIconPicker = false;
        editingTodo = new();
    }

    private async Task SaveTodo()
    {
        if (string.IsNullOrWhiteSpace(editingTodo.Title))
            return;

        if (editingTodo.Id > 0)
        {
            await TodoService.UpdateTodoAsync(editingTodo);
        }
        else
        {
            await TodoService.CreateTodoAsync(editingTodo);
        }

        CloseModal();
        await LoadData();
    }

    private async Task ToggleComplete(int id)
    {
        await TodoService.ToggleCompleteAsync(id);
        await LoadData();
    }

    private async Task DeleteTodo(int id)
    {
        await TodoService.DeleteTodoAsync(id);
        await LoadData();
    }

    private string GetPriorityClass(string priority)
    {
        return priority switch
        {
            "High" => "bg-red-100 text-red-700",
            "Medium" => "bg-yellow-100 text-yellow-700",
            "Low" => "bg-green-100 text-green-700",
            _ => "bg-gray-100 text-gray-700"
        };
    }

    private string GetBorderColor(string priority)
    {
        return priority switch
        {
            "High" => "border-red-500",
            "Medium" => "border-yellow-500",
            "Low" => "border-green-500",
            _ => "border-gray-300"
        };
    }

    private string GetPriorityText(string priority)
    {
        return priority switch
        {
            "High" => "高",
            "Medium" => "中",
            "Low" => "低",
            _ => priority
        };
    }

    private MarkupString GetPriorityIcon(string priority)
    {
        var icon = priority switch
        {
            "High" => "🔴",
            "Medium" => "🟡",
            "Low" => "🟢",
            _ => "⚪"
        };
        return new MarkupString($"<span class='mr-1'>{icon}</span>");
    }
}
